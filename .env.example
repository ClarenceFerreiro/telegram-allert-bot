# ──────────────────────────────────────────────────────────────
#  Telegram Alert Bot — переменные окружения
#  Скопируйте этот файл в .env и заполните значениями.
#  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Токен Telegram-бота (получить у @BotFather: https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# GitHub Personal Access Token (PAT) со scopes: repo, workflow
# Создать: https://github.com/settings/tokens (classic) → generate new token
PAT_TOKEN=ghp_your_github_pat_token_here

# Telegram user ID для ограничения доступа (только этот пользователь может управлять ботом)
# Узнать свой ID: @userinfobot → /start
TELEGRAM_USER_ID=405995403

# Список отслеживаемых репозиториев (через запятую, формат: owner/repo)
GITHUB_REPOS=ClarenceFerreiro/postman-api-tests

# Workflow для запуска командой /run (имя файла в .github/workflows/)
DEFAULT_WORKFLOW=allure-report.yml

# Ветка для запуска workflow по умолчанию
DEFAULT_BRANCH=main

# Базовый URL Allure-отчётов (GitHub Pages)
REPORT_BASE_URL=https://clarenceferreiro.github.io/postman-api-tests/